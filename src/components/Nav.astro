---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const path = Astro.url.pathname.replace(/\/$/, '');

const links = [
  { label: 'About',    href: `${base}/` },
  { label: 'Projects', href: `${base}/projects` },
  { label: 'Resume',   href: `${base}/resume` },
  { label: 'Contact',  href: `${base}/contact` },
];

function isActive(href: string): boolean {
  const normalized = href.replace(/\/$/, '');
  if (normalized === base) return path === base || path === `${base}/`;
  return path === normalized || path.startsWith(normalized + '/');
}
---

<nav class="container nav-inner">
  <a href={`${base}/`} class="brand">Hunter Myers</a>
  <ul class="nav-links">
    {links.map(({ label, href }) => (
      <li>
        <a href={href} class:list={['nav-link', { active: isActive(href) }]}>
          {label}
        </a>
      </li>
    ))}
  </ul>
</nav>
